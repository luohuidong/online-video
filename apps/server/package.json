{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "drizzle-kit push && ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "nest build",
    "start": "node dist/main",
    "typecheck": "tsc --noEmit",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:push": "drizzle-kit push"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "better-sqlite3": "^12.0.0",
    "drizzle-orm": "^0.45.2",
    "js-yaml": "^4.1.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
